{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "host": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/host",
      "sourceRoot": "projects/host/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-architects/native-federation-v4:build",
          "options": {
						"cacheExternalArtifacts": true,
            "tsConfig": "projects/host/tsconfig.federation.json",
            "entryPoints": [
              "projects/host/src/main.ts"
            ]
          },
          "configurations": {
            "production": {
              "target": "host:esbuild:production"
            },
            "development": {
              "target": "host:esbuild:development",
              "dev": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-architects/native-federation-v4:build",
          "options": {
            "target": "host:serve-original:development",
            "tsConfig": "projects/host/tsconfig.federation.json",
						"cacheExternalArtifacts": true,
						"rebuildDelay": 500,
            "dev": true,
            "port": 0
          }
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "buildTarget": "host:esbuild:development",
            "setupFiles": [
              "libs/event-bus/src/testing/install-registry-stub.ts"
            ]
          }
        },
        "esbuild": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/host",
            "verbose": false,
            "index": "projects/host/src/index.html",
            "browser": "projects/host/src/main.ts",
            "polyfills": [
              "es-module-shims"
            ],
            "tsConfig": "projects/host/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/host/public"
              }
            ],
            "styles": [
              "projects/host/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve-original": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "host:esbuild:production"
            },
            "development": {
              "buildTarget": "host:esbuild:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "port": 4200
          }
        }
      }
    },
