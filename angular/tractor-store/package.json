{
  "name": "mfe-test",
  "version": "1.2.3",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "cdn": "http-server ./public -p 3000 --cors -c-1 --silent",
    "start:all": "concurrently -n cdn,explore,decide,checkout,host \"pnpm cdn\" \"ng serve explore\" \"ng serve decide\" \"ng serve checkout\" \"ng serve host\"",
